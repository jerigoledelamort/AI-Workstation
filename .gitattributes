# Line endings: LF по умолчанию, CRLF для Windows-скриптов
* text=auto eol=lf

# Windows-specific scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.7z binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.pyc binary
*.bin binary
*.safetensors binary
*.gguf binary
*.pt binary
*.bin binary

# Model files
*.gguf filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text
