{
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
    "python.terminal.activateEnvironment": true,
    "editor.formatOnSave": true,
    "files.encoding": "utf8",
    "files.eol": "\n",
    "search.exclude": {
        "**/.venv": true,
        "**/site": true,
        "**/__pycache__": true,
        "**/uv.lock": false
    },
    "files.exclude": {
        "**/.git": true,
        "**/.venv": true,
        "**/site": true,
        "**/__pycache__": true
    }
}